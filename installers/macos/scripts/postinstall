#!/bin/bash
set -e
# Payload staged to /usr/local/keld; symlink the CLIs onto PATH, keep the sidecar
# and onboard.command beside keld-agent so sidecarBinPath()/the script resolve them.
PREFIX="/usr/local/keld"
# /usr/local/bin isn't guaranteed to exist — on an Apple-Silicon Mac with no
# Homebrew in /usr/local (Homebrew lives in /opt/homebrew), it's often absent.
# Under `set -e` a failing `ln` into a missing dir aborts the whole postinstall
# and fails the install, so ensure the target dir exists first.
mkdir -p /usr/local/bin
ln -sf "$PREFIX/keld" /usr/local/bin/keld
ln -sf "$PREFIX/keld-agent" /usr/local/bin/keld-agent

uid=$(stat -f %u /dev/console)
user=$(id -un "$uid")

# Idempotent install: repoint any stray keld/keld-agent in OTHER known PATH
# locations to this canonical install, so an older copy (e.g. a prior curl|sh
# install in ~/.local/bin) can't shadow it for the CLI or the tool hooks. We only
# touch files that already exist (never create new ones), and only when they
# aren't already the canonical symlink. Best-effort under `set -e`.
userhome=$(dscl . -read /Users/"$user" NFSHomeDirectory 2>/dev/null | awk '{print $2}')
for d in ${userhome:+"$userhome/.local/bin"} /opt/homebrew/bin; do
  for b in keld keld-agent; do
    t="$d/$b"
    canon="$PREFIX/$b"
    if { [ -e "$t" ] || [ -L "$t" ]; } && [ "$(readlink "$t" 2>/dev/null)" != "$canon" ]; then
      sudo -u "$user" ln -sf "$canon" "$t" 2>/dev/null || true
    fi
  done
done

# Replace the running process: restart the per-user agent so the live daemon is
# THIS build, not a lingering older one from a previous install. Best-effort —
# a no-op if it isn't loaded yet (a first install loads it via onboard.command).
launchctl kickstart -k "gui/$uid/co.keld.agent" 2>/dev/null || true

# Onboarding runs in the user's GUI session and registers/starts the agent itself
# (after login + setup), so the agent isn't started before the user is set up.
if [ -f "$PREFIX/onboard.command" ]; then
  chmod +x "$PREFIX/onboard.command" || true
  launchctl asuser "$uid" sudo -u "$user" open "$PREFIX/onboard.command" || true
fi

exit 0
