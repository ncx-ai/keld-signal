{
  "theme": "dark",
  "telemetry": {
    "enabled": true,
    "target": "local",
    "otlpProtocol": "http",
    "otlpEndpoint": "https://atlas.keld.co",
    "logPrompts": false
  },
  "hooks": {
    "BeforeAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "keld __hook --source gemini"
          }
        ]
      }
    ]
  }
}
